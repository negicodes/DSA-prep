// second largest

import java.util.*;
public static void main(String[] args){
    int arr[] = {1,2,3,4,5};
    int max = arr[0];
    int second_max = arr[1];
    for(int i = 0; i < arr.length; i++){
        if(max<arr[i]){
            second_max = max;
            max = arr[i];
        }else if(second_max<arr[i] && second_max != max){
            second_max = arr[i];
        }
    }
    System.out.println(second_max);

}
